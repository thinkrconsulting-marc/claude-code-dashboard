# Copy this file to .env and fill in the real values
# NEVER commit .env to git - it contains secrets

# Database (PostgreSQL)
DATABASE_URL='postgresql://user:password@host:5432/dbname?connect_timeout=15'

# NextAuth
NEXTAUTH_SECRET=generate-a-random-32-char-string-here
# NEXTAUTH_URL is auto-set in production, leave empty for local dev

# Google Gemini (https://aistudio.google.com/apikey)
GEMINI_API_KEY=AIzaSy...

# YouTube Data API v3 (https://console.cloud.google.com/apis/credentials)
YOUTUBE_API_KEY=AIzaSy...

# AWS S3 (for file uploads) - optional on Railway
AWS_REGION=us-west-2
AWS_BUCKET_NAME=your-bucket-name
AWS_FOLDER_PREFIX=uploads/
# For local dev only:
# AWS_PROFILE=default
# For Railway/production use IAM keys instead:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
